---
import { getSite } from '../lib/data.js'

const site = getSite()
const year = new Date().getFullYear()
---

<footer>
  <div class="footer-inner">
    <p class="footer-name">{site.name.toUpperCase()}</p>
    <p class="footer-location">{site.location}</p>

    {site.social && (
      <div class="social-links">
        {site.social.instagram && (
          <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.01" fill="currentColor" stroke-width="2"/>
            </svg>
          </a>
        )}
        {site.social.facebook && (
          <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        )}
        {site.social.twitter && (
          <a href={site.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter / X">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        )}
      </div>
    )}

    <p class="footer-copy">
      &copy; {year} {site.copyright ?? site.name}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  footer {
    margin-top: 6rem;
    border-top: 1px solid var(--border);
    padding: 3rem 2.5rem;
    text-align: center;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.2em;
  }

  .footer-location {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .social-links {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    margin: 0.5rem 0;
  }

  .social-links a {
    color: var(--muted);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .social-links a:hover {
    color: var(--text);
  }

  .footer-copy {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin-top: 0.5rem;
  }
</style>
