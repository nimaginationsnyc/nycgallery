---
interface Props {
  artworks: Array<{
    title: string
    imageUrl: string
    medium: string
    size: string
    year: number
    available: boolean
  }>
  contactUrl: string
}

const { artworks, contactUrl } = Astro.props
---

<div id="lightbox" role="dialog" aria-modal="true" aria-label="Artwork detail" aria-hidden="true">
  <button class="lb-close" id="lb-close" aria-label="Close">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <button class="lb-nav lb-prev" id="lb-prev" aria-label="Previous artwork">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>

  <div class="lb-inner">
    <div class="lb-image-wrap">
      <img id="lb-img" src="" alt="" />
    </div>

    <div class="lb-details">
      <p class="lb-counter" id="lb-counter"></p>
      <h2 class="lb-title" id="lb-title"></h2>
      <dl class="lb-meta">
        <div class="lb-meta-row">
          <dt>Medium</dt>
          <dd id="lb-medium"></dd>
        </div>
        <div class="lb-meta-row">
          <dt>Size</dt>
          <dd id="lb-size"></dd>
        </div>
        <div class="lb-meta-row">
          <dt>Year</dt>
          <dd id="lb-year"></dd>
        </div>
        <div class="lb-meta-row" id="lb-status-row">
          <dt>Status</dt>
          <dd id="lb-status"></dd>
        </div>
      </dl>
      <a id="lb-inquire" href={contactUrl} class="lb-inquire">Inquire About This Work</a>
    </div>
  </div>

  <button class="lb-nav lb-next" id="lb-next" aria-label="Next artwork">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>
</div>

<script define:vars={{ artworks }}>
  let current = 0

  const lb        = document.getElementById('lightbox')
  const lbImg     = document.getElementById('lb-img')
  const lbTitle   = document.getElementById('lb-title')
  const lbMedium  = document.getElementById('lb-medium')
  const lbSize    = document.getElementById('lb-size')
  const lbYear    = document.getElementById('lb-year')
  const lbStatus  = document.getElementById('lb-status')
  const lbCounter = document.getElementById('lb-counter')
  const lbInquire = document.getElementById('lb-inquire')

  function render(index) {
    const aw = artworks[index]
    lbImg.style.opacity = '0'
    setTimeout(() => {
      lbImg.src = aw.imageUrl
      lbImg.alt = aw.title
      lbImg.onload = () => { lbImg.style.opacity = '1' }
    }, 80)
    lbTitle.textContent  = aw.title
    lbMedium.textContent = aw.medium ?? '—'
    lbSize.textContent   = aw.size   ?? '—'
    lbYear.textContent   = aw.year   ?? '—'
    lbCounter.textContent = `${index + 1} / ${artworks.length}`
    if (aw.available) {
      lbStatus.textContent = 'Available'
      lbStatus.className = 'status-available'
      lbInquire.style.display = 'inline-block'
    } else {
      lbStatus.textContent = 'Not Available'
      lbStatus.className = 'status-sold'
      lbInquire.style.display = 'none'
    }
  }

  function open(index) {
    current = ((index % artworks.length) + artworks.length) % artworks.length
    render(current)
    lb.classList.add('open')
    lb.setAttribute('aria-hidden', 'false')
    document.body.style.overflow = 'hidden'
  }

  function close() {
    lb.classList.remove('open')
    lb.setAttribute('aria-hidden', 'true')
    document.body.style.overflow = ''
  }

  function prev() { current = (current - 1 + artworks.length) % artworks.length; render(current) }
  function next() { current = (current + 1) % artworks.length; render(current) }

  document.getElementById('lb-close').addEventListener('click', close)
  document.getElementById('lb-prev').addEventListener('click', prev)
  document.getElementById('lb-next').addEventListener('click', next)

  lb.addEventListener('click', e => { if (e.target === lb) close() })

  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return
    if (e.key === 'Escape')      close()
    if (e.key === 'ArrowLeft')   prev()
    if (e.key === 'ArrowRight')  next()
  })

  // Touch swipe
  let touchX = null
  lb.addEventListener('touchstart', e => { touchX = e.touches[0].clientX }, { passive: true })
  lb.addEventListener('touchend', e => {
    if (touchX === null) return
    const diff = touchX - e.changedTouches[0].clientX
    if (Math.abs(diff) > 50) diff > 0 ? next() : prev()
    touchX = null
  }, { passive: true })

  // Expose globally so gallery cards can call it
  window.__lbOpen = open
</script>

<style>
  #lightbox {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(14, 13, 12, 0.96);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s var(--ease);
  }

  #lightbox.open {
    opacity: 1;
    pointer-events: all;
  }

  .lb-inner {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3.5rem;
    width: 92%;
    max-width: 1300px;
    max-height: 92vh;
    align-items: center;
  }

  .lb-image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    max-height: 88vh;
    overflow: hidden;
  }

  .lb-image-wrap img {
    max-width: 100%;
    max-height: 88vh;
    object-fit: contain;
    transition: opacity 0.18s var(--ease);
  }

  .lb-details {
    color: #e8e4dc;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .lb-counter {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6b6560;
  }

  .lb-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    line-height: 1.25;
    color: #f5f0e8;
  }

  .lb-meta {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .lb-meta-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.5rem;
    font-size: 0.78rem;
  }

  .lb-meta-row dt {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b6560;
    padding-top: 1px;
  }

  .lb-meta-row dd {
    color: #c8c0b4;
  }

  .status-available { color: #a8c4a0; }
  .status-sold      { color: #7a7068; }

  .lb-inquire {
    display: inline-block;
    padding: 0.8rem 1.6rem;
    border: 1px solid rgba(255,255,255,0.25);
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #e8e4dc;
    text-decoration: none;
    transition: background 0.25s, border-color 0.25s;
    align-self: flex-start;
  }

  .lb-inquire:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.5);
  }

  /* Close button */
  .lb-close {
    position: absolute;
    top: 1.5rem;
    right: 1.75rem;
    background: none;
    border: none;
    color: #9b9589;
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.2s;
    z-index: 10;
  }

  .lb-close:hover { color: #f5f0e8; }

  /* Prev / Next */
  .lb-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #6b6560;
    cursor: pointer;
    padding: 1rem 0.75rem;
    transition: color 0.2s;
    z-index: 10;
  }

  .lb-nav:hover { color: #f5f0e8; }
  .lb-prev { left: 0.5rem; }
  .lb-next { right: 0.5rem; }

  /* Mobile */
  @media (max-width: 768px) {
    .lb-inner {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      overflow-y: auto;
      gap: 1.5rem;
      padding: 4rem 1.25rem 2rem;
      align-items: start;
      max-height: 100dvh;
      width: 100%;
    }

    .lb-image-wrap {
      max-height: 55vw;
      min-height: 240px;
    }

    .lb-title { font-size: 1.6rem; }

    .lb-nav { display: none; }
  }
</style>
